{
  "name": "vitaeflow",
  "version": "0.1.0",
  "description": "CLI for the VitaeFlow open standard — validate, embed, extract, and inspect structured resumes in PDFs.",
  "type": "module",
  "bin": {
    "vitaeflow": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitaeflow/sdk": "file:../vitaeflow-js",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.10"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vitaeflow",
    "resume",
    "cv",
